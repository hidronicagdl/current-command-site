---
// src/pages/blog/[slug].astro
import { getCollection, render } from 'astro:content'; 
import Layout from '../../layouts/Layout.astro';
import FaqSection from '../../components/FaqSection.astro'; // 1. Importar el nuevo componente







export async function getStaticPaths() {
  const blogEntries = await getCollection('blog');
  return blogEntries.map(entry => ({
    params: { slug: entry.id }, 
    props: { entry },
  }));
}

const { entry } = Astro.props;
const { Content } = await render(entry); 

// ESTRATEGIA SEO CRÍTICA: Romper la duplicación exacta de Meta Title y H1
const seoTitle = entry.data.metaTitle || `${entry.data.title} | CurrentCommand`;


// CONSTRUCCIÓN DEL OBJETO SCHEMA JSON-LD PARA OPTIMIZACIÓN GENERATIVA (GEO)
// Determinamos la URL absoluta de forma dinámica para consolidar la entidad web
const canonicalURL = new URL(Astro.url.pathname, 'https://currentcommand.com');

const jsonLd = {
  "@context": "https://schema.org",
  "@type": "TechArticle",
  "headline": entry.data.title,
  "description": entry.data.description,
  "datePublished": entry.data.pubDate,
  "dateModified": entry.data.dateModified || entry.data.pubDate,


  "author": {
    "@type": "Person",
    "name": entry.data.author || "José Aguilar",
    "jobTitle": "Vendedor y Gerente de Nuevas Tecnologías",
    "url": "https://currentcommand.com",
    
    // El puente de confianza: Relación con la empresa real
    "worksFor": {
      "@type": "Organization",
      "name": "Soluciones Integrales en Bombeo Inteligente (SIBI)",
      "url": "https://sibi.mx"
    },
    
    // El núcleo del Gráfico de Conocimiento: Tus canales de autoridad
    "sameAs": [
      "https://www.linkedin.com/in/jose-gpe-aguilar",
      "https://www.youtube.com/@JoseAguilar-bombas",
	  "https://www.youtube.com/@sibigdl"
    ]
  },
  
  "publisher": {
    "@type": "Organization",
    "name": "CurrentCommand",
    "url": "https://currentcommand.com"
  },
  "mainEntityOfPage": {
    "@type": "WebPage",
    "@id": canonicalURL.href
  },
  "inLanguage": "es-MX",
  // Inyección dinámica de entidades para que los LLMs (Gemini, Perplexity) entiendan el contexto exacto
  "about": [
    ...(entry.data.brandEntity ? [{ "@type": "Brand", "name": entry.data.brandEntity }] : []),
    ...(entry.data.geoEntities ? entry.data.geoEntities.map((entidad: string) => ({ "@type": "Thing", "name": entidad })) : [])
  ]  
};

// 2. CONSTRUCCIÓN AUTOMATIZADA DEL SCHEMA FAQPAGE PARA ROBOTS DE IA
let faqJsonLd = null;
if (entry.data.faqs && entry.data.faqs.length > 0) {
  faqJsonLd = {
    "@context": "https://schema.org",
    "@type": "FAQPage",
    "mainEntity": entry.data.faqs.map((faq: any) => ({
      "@type": "Question",
      "name": faq.question,
      "acceptedAnswer": {
        "@type": "Answer",
        "text": faq.answer
      }
    }))
  };
}
// LÍNEA DE MONITOREO INDUSTRIAL: Ver los datos crudos en la consola de tu computadora
console.log("Campos detectados por Astro en este post:", Object.keys(entry.data));
---

<Layout title={seoTitle} description={entry.data.description}>
  {/* INYECCIÓN DE DATOS ESTRUCTURADOS: Uso de set:html e is:inline para evitar escapes de caracteres en el build */}
  <script type="application/ld+json" slot="head" set:html={JSON.stringify(jsonLd)} />

{faqJsonLd && (
    <script type="application/ld+json" slot="head" set:html={JSON.stringify(faqJsonLd)} />
  )}

  <main class="max-w-4xl mx-auto px-6 py-12 md:py-16">
    <article class="text-steel-gray">
      
      <header class="mb-8 border-b border-gray-100 pb-6">
        <h1 class="text-3xl md:text-4xl font-extrabold text-slate-900 mb-4 tracking-tight leading-tight">
          {entry.data.title}
        </h1>
        <p class="text-sm text-gray-500 font-sans">
          {entry.data.pubDate && `Publicado el: ${entry.data.pubDate} | `}{entry.data.author && `Por: ${entry.data.author}`}
        </p>
      </header>
      
      <div class="markdown-content">
        <Content />
      </div>
	  
	  <FaqSection faqs={entry.data.faqs} />

    </article>
  </main>
</Layout>

<style is:global>
  /* ==========================================================================
     HOJA DE ESTILOS PROFESIONAL BLINDADA PARA PRODUCCIÓN (NETLIFY B2B)
     ========================================================================== */

  /* Párrafos integrados y fluidos con especificidad incrementada */
  main article .markdown-content p {
    font-size: 1rem;
    line-height: 1.8;
    color: #374151 !important;
    margin-bottom: 1.5rem !important;
    text-align: justify;
  }
  
  @media (min-width: 768px) {
    main article .markdown-content p {
      text-align: left;
    }
  }

  /* Títulos h2 con Jerarquía de Autoridad */
  main article .markdown-content h2 {
    font-size: 1.625rem !important;
    font-weight: 700 !important;
    color: #0f172a !important;
    margin-top: 2.75rem !important;
    margin-bottom: 1.25rem !important;
    letter-spacing: -0.025em;
    line-height: 1.3;
    display: block;
  }

  /* Subtítulos h3 */
  main article .markdown-content h3 {
    font-size: 1.3rem !important;
    font-weight: 600 !important;
    color: #1e293b !important;
    margin-top: 2.25rem !important;
    margin-bottom: 1rem !important;
    letter-spacing: -0.02em;
    display: block;
  }

  /* Énfasis de ingeniería */
  main article .markdown-content strong {
    font-weight: 700 !important;
    color: #0f172a !important;
  }

  /* Tablas Comparativas Industriales Resilientes al Reset de Tailwind */
  main article .markdown-content table {
    width: 100% !important;
    margin-top: 2.5rem !important;
    margin-bottom: 2.5rem !important;
    border-collapse: collapse !important;
    font-size: 0.9rem !important;
    background-color: #ffffff !important;
    border-radius: 0.5rem !important;
    overflow: hidden !important;
    border: 1px solid #e2e8f0 !important;
    display: table !important;
  }

  main article .markdown-content th {
    background-color: #1e293b !important;
    color: #ffffff !important;
    font-weight: 600 !important;
    padding: 0.85rem 1.25rem !important;
    text-align: left !important;
    border: 1px solid #e2e8f0 !important;
  }

  main article .markdown-content td {
    padding: 0.85rem 1.25rem !important;
    border: 1px solid #e2e8f0 !important;
    color: #334155 !important;
    line-height: 1.5 !important;
  }

  main article .markdown-content tr:nth-child(even) {
    background-color: #f8fafc !important;
  }

  /* Hipervínculos e Interconexión Estricta de Silos */
  main article .markdown-content a {
    color: #2563eb !important;
    text-decoration: underline !important;
    font-weight: 600 !important;
    text-underline-offset: 4px;
    transition: color 0.2s ease;
  }

  main article .markdown-content a:hover {
    color: #1d4ed8 !important;
  }

  /* Listas residuales complementarias */
  main article .markdown-content ul {
    list-style-type: disc !important;
    margin-bottom: 1.5rem !important;
    padding-left: 1.5rem !important;
    display: block !important;
  }
  
  main article .markdown-content li {
    margin-bottom: 0.5rem !important;
    line-height: 1.7 !important;
    color: #374151 !important;
    display: list-item !important;
  }
</style>