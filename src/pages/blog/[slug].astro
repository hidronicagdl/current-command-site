---
// src/pages/blog/[slug].astro
import { getCollection } from 'astro:content';
import Layout from '../../layouts/Layout.astro';

export async function getStaticPaths() {
  const blogEntries = await getCollection('blog');
  return blogEntries.map(entry => ({
    params: { slug: entry.slug }, props: { entry },
  }));
}

const { entry } = Astro.props;
const { Content } = await entry.render();
---

<Layout title={entry.data.title} description={entry.data.description}>
  <main class="max-w-4xl mx-auto px-6 py-12 md:py-16">
    <article class="text-steel-gray">
      
      <header class="mb-8 border-b border-gray-100 pb-6">
        <h1 class="text-3xl md:text-4xl font-extrabold text-slate-900 mb-4 tracking-tight leading-tight">
          {entry.data.title}
        </h1>
        <p class="text-sm text-gray-500 font-sans">
          Publicado el: {entry.data.pubDate} | Por: {entry.data.author}
        </p>
      </header>
      
      <div class="markdown-content">
        <Content />
      </div>

    </article>
  </main>
</Layout>

<style is:global>
  /* ==========================================================================
     HOJA DE ESTILOS PROFESIONAL PARA CONTENIDO EDITORIAL B2B (MARKDOWN)
     ========================================================================== */

  /* Párrafos integrados y fluidos */
  .markdown-content p {
    font-size: 1rem;
    line-height: 1.8;
    color: #374151; /* text-gray-700 */
    margin-bottom: 1.5rem;
    text-align: justify;
  }
  
  @media (min-width: 768px) {
    .markdown-content p {
      text-align: left; /* Alineación limpia en pantallas grandes */
    }
  }

  /* Títulos y Subtítulos con Jerarquía Robusta */
  .markdown-content h2 {
    font-size: 1.625rem;
    font-weight: 700;
    color: #0f172a; /* text-slate-900 */
    margin-top: 2.75rem;
    margin-bottom: 1.25rem;
    letter-spacing: -0.025em;
    line-height: 1.3;
  }

  .markdown-content h3 {
    font-size: 1.3rem;
    font-weight: 600;
    color: #1e293b; /* text-slate-800 */
    margin-top: 2.25rem;
    margin-bottom: 1rem;
    letter-spacing: -0.02em;
  }

  /* Énfasis técnico */
  .markdown-content strong {
    font-weight: 700;
    color: #0f172a;
  }

  /* Estilos Avanzados para Tablas Comparativas Industriales */
  .markdown-content table {
    width: 100%;
    margin-top: 2.5rem;
    margin-bottom: 2.5rem;
    border-collapse: collapse;
    font-size: 0.9rem;
    background-color: #ffffff;
    border-radius: 0.5rem;
    overflow: hidden;
    border: 1px solid #e2e8f0;
    box-shadow: 0 1px 3px 0 rgba(0, 0, 0, 0.05);
  }

  .markdown-content th {
    background-color: #1e293b; /* Fondo oscuro de ingeniería corporativa */
    color: #ffffff;
    font-weight: 600;
    padding: 0.85rem 1.25rem;
    text-align: left;
    border: 1px solid #e2e8f0;
  }

  .markdown-content td {
    padding: 0.85rem 1.25rem;
    border: 1px solid #e2e8f0;
    color: #334155;
    line-height: 1.5;
  }

  .markdown-content tr:nth-child(even) {
    background-color: #f8fafc; /* Alternancia sutil de renglones para lectura veloz */
  }

  /* Estilos para Hipervínculos e Interconexión de Silos */
  .markdown-content a {
    color: #2563eb; /* Azul de conversión */
    text-decoration: underline;
    font-weight: 600;
    text-underline-offset: 4px;
    transition: color 0.2s ease;
  }

  .markdown-content a:hover {
    color: #1d4ed8;
    text-decoration-color: #1d4ed8;
  }

  /* Listas complementarias residuales */
  .markdown-content ul {
    list-style-type: disc;
    margin-bottom: 1.5rem;
    padding-left: 1.5rem;
  }
  
  .markdown-content li {
    margin-bottom: 0.5rem;
    line-height: 1.7;
    color: #374151;
  }
</style>