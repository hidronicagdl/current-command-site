---
// Dentro del frontmatter (parte superior) de src/pages/blog/index.astro
import { getCollection } from 'astro:content';
import Layout from '../../layouts/Layout.astro';

const posts = await getCollection('blog');

const sortedPosts = posts.sort((a, b) => {
  const dateA = a.data.pubDate || a.data.date || a.data.fecha;
  const dateB = b.data.pubDate || b.data.date || b.data.fecha;
  return new Date(dateB).valueOf() - new Date(dateA).valueOf();
});

const formatDate = (postData: any) => {
  const rawDate = postData.pubDate || postData.date || postData.fecha;
  
  if (!rawDate) return 'Documento Técnico';
  
  // Forzamos la conversión a objeto Date estableciendo la hora en UTC para evitar desfases de días
  const date = new Date(rawDate);
  
  if (isNaN(date.getTime())) {
    // Si es un texto plano indescifrable por JS, lo imprimimos tal cual limpiando comillas
    return String(rawDate).replace(/['"]+/g, '');
  }
  
  return date.toLocaleDateString('es-MX', {
    year: 'numeric',
    month: 'long',
    day: 'numeric',
    timeZone: 'UTC' // Mantiene la consistencia de la fecha del servidor en México
  });
};
---


<Layout title="Blog Técnico B2B | CURRENT COMMAND">
  <main class="max-w-6xl mx-auto px-6 py-16">
    {/* Se preserva tu cabecera original perfectamente centrada */}
    <header class="mb-16 text-center">
      <h1 class="text-4xl font-bold text-slate-900 mb-4">Ingeniería y Casos de Éxito</h1>
      <p class="text-lg text-gray-600 max-w-2xl mx-auto">
        Conocimiento técnico, análisis comparativos y estrategias de mitigación de riesgos en sistemas de bombeo inteligente.
      </p>
    </header>

    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
      {sortedPosts.map((post) => (
        <article class="bg-white border border-gray-200 rounded-lg shadow-sm overflow-hidden hover:shadow-lg transition-shadow duration-300 flex flex-col">
          <div class="p-6 flex-1 flex flex-col">
            
            {/* CORREGIDO: Uso de la función protectora de fechas regionales */}
            <div class="text-sm text-blue-600 font-semibold mb-3 uppercase tracking-wider">
              {formatDate(post.data.pubDate)}
            </div>
            
            {/* CORREGIDO: El enlace del título ahora apunta a post.id en lugar de post.slug */}
            <h2 class="text-xl font-bold text-slate-900 mb-3 leading-snug">
              <a href={`/blog/${post.id}`} class="hover:text-blue-700 transition-colors">
                {post.data.title}
              </a>
            </h2>
            
            <p class="text-gray-600 mb-6 flex-1 line-clamp-3">
              {post.data.description}
            </p>
            
            <div class="mt-auto">
              {/* CORREGIDO: El enlace de lectura ahora apunta a post.id en lugar de post.slug */}
              <a href={`/blog/${post.id}`} class="inline-flex items-center text-blue-600 font-medium hover:text-blue-800 transition-colors">
                Leer análisis técnico
                <svg class="w-4 h-4 ml-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M14 5l7 7m0 0l-7 7m7-7H3" />
                </svg>
              </a>
            </div>
          </div>
        </article>
      ))}
    </div>
  </main>
</Layout>