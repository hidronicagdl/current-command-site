---
import { getCollection } from 'astro:content';
import Layout from '../../layouts/Layout.astro';

// Aquí le pedimos a Astro que traiga todos los artículos y los ordene por fecha (el más reciente primero)
const posts = await getCollection('blog');
const sortedPosts = posts.sort((a, b) => new Date(b.data.pubDate).valueOf() - new Date(a.data.pubDate).valueOf());
---

<Layout title="Blog Técnico B2B | CURRENT COMMAND">
  <main class="max-w-6xl mx-auto px-6 py-16">
    <header class="mb-16 text-center">
      <h1 class="text-4xl font-bold text-slate-900 mb-4">Ingeniería y Casos de Éxito</h1>
      <p class="text-lg text-gray-600 max-w-2xl mx-auto">
        Conocimiento técnico, análisis comparativos y estrategias de mitigación de riesgos en sistemas de bombeo inteligente.
      </p>
    </header>

    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
      {sortedPosts.map((post) => (
        <article class="bg-white border border-gray-200 rounded-lg shadow-sm overflow-hidden hover:shadow-lg transition-shadow duration-300 flex flex-col">
          <div class="p-6 flex-1 flex flex-col">
            <div class="text-sm text-blue-600 font-semibold mb-3 uppercase tracking-wider">
              {new Date(post.data.pubDate).toLocaleDateString('es-MX', { year: 'numeric', month: 'long', day: 'numeric' })}
            </div>
            
            <h2 class="text-xl font-bold text-slate-900 mb-3 leading-snug">
              <a href={`/blog/${post.slug}`} class="hover:text-blue-700 transition-colors">
                {post.data.title}
              </a>
            </h2>
            
            <p class="text-gray-600 mb-6 flex-1 line-clamp-3">
              {post.data.description}
            </p>
            
            <div class="mt-auto">
              <a href={`/blog/${post.slug}`} class="inline-flex items-center text-blue-600 font-medium hover:text-blue-800 transition-colors">
                Leer análisis técnico
                <svg class="w-4 h-4 ml-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M14 5l7 7m0 0l-7 7m7-7H3" />
                </svg>
              </a>
            </div>
          </div>
        </article>
      ))}
    </div>
  </main>
</Layout>