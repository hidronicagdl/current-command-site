---
// src/pages/eventos/index.astro
import Layout from '../../layouts/Layout.astro';
---

<Layout 
  title="Capacitaciones Técnicas de Ingeniería Hidráulica y HVAC 2026 | SIBI" 
  description="Seminarios presenciales de especialización técnica para ingenieros, contratistas y proyectistas. Co-patrocinado por SIBI, Zoeller y Grundfos en Guadalajara y Tlaquepaque."
  minimal={true}
>
  <!-- Inyección de Datos Estructurados para Motores de IA y Búsqueda (GEO / SEO) -->
  <Fragment slot="head">
    <meta name="robots" content="index, follow" />
    <link rel="canonical" href="https://currentcommand.com/eventos" />

    <!-- Open Graph (SEM / Social) -->
    <meta property="og:type" content="website" />
    <meta property="og:title" content="Seminarios y Capacitaciones Técnicas de Ingeniería Hidráulica 2026" />
    <meta property="og:description" content="Actualización de alto nivel en bombeo de aguas negras y ahorro energético en HVAC con Zoeller y Grundfos." />
    <meta property="og:url" content="https://currentcommand.com/eventos" />

    <!-- Marcado Schema ItemList para Indexación de Calendarios por IA -->
    <script type="application/ld+json" is:inline>
      {
        "@context": "https://schema.org",
        "@type": "ItemList",
        "itemListElement": [
          {
            "@type": "ListItem",
            "position": 1,
            "item": {
              "@type": "BusinessEvent",
              "name": "Curso Técnico Zoeller: Bombeo de Aguas Negras y Cárcamos Presurizados",
              "startDate": "2026-08-06T09:00:00-06:00",
              "url": "https://currentcommand.com/eventos/zoeller",
              "location": {
                "@type": "Place",
                "name": "Instalaciones de Zoeller México",
                "address": "Zapopan, Jalisco"
              }
            }
          },
          {
            "@type": "ListItem",
            "position": 2,
            "item": {
              "@type": "BusinessEvent",
              "name": "Curso Técnico Grundfos: Ahorro Energético en HVAC y Bombeo Distribuido",
              "startDate": "2026-08-27T11:00:00-06:00",
              "url": "https://currentcommand.com/eventos/grundfos",
              "location": {
                "@type": "Place",
                "name": "Cámara de Comercio de Tlaquepaque",
                "address": "San Pedro Tlaquepaque, Jalisco"
              }
            }
          }
        ]
      }
    </script>
  </Fragment>

  <!-- Navegación Aislada de Alta Autoridad -->
  <nav class="navbar-hub">
    <div class="nav-container-hub">
      <div class="brand-logos-hub">
        <span class="logo-sibi">SIBI</span>
        <span class="logo-divider">|</span>
        <span class="logo-sub">CAPACITACIÓN TÉCNICA</span>
      </div>
      <div class="nav-meta-hub">
        <span class="badge-year">CALENDARIO 2026</span>
      </div>
    </div>
  </nav>

  <!-- Hero Section Del Hub -->
  <header class="hero-hub">
    <div class="hero-container-hub">
      <p class="hero-kicker">PROGRAMA DE ACTUALIZACIÓN TÉCNICA PRESENCIAL</p>
      <h1>Seminarios Presenciales de Ingeniería Hidráulica y Climatización 2026</h1>
      <p class="hero-lead">
        Especialización de alto rendimiento en sistemas de bombeo de aguas negras, cárcamos presurizados y eficiencia energética en HVAC. Co-patrocinado por <strong>SIBI</strong>, <strong>Zoeller</strong> y <strong>Grundfos</strong> en Jalisco.
      </p>
    </div>
  </header>

  <!-- Grid Principal de Eventos -->
  <main class="main-hub-content">
    <div class="section-container">
      <div class="events-grid">

        <!-- TARJETA 1: EVENTO ZOELLER -->
        <article class="event-card border-zoeller">
          <div class="card-header">
            <span class="badge-tech badge-zoeller">AGUAS NEGRAS / CÁRCAMOS</span>
            <span class="event-status">CUPO LIMITADO</span>
          </div>

          <div class="card-body">
            <h3>Curso Técnico Zoeller: Bombeo de Aguas Negras y Cárcamos Presurizados</h3>
            
            <ul class="event-meta-list">
              <li>📅 <strong>Fecha:</strong> 6 de Agosto, 2026</li>
              <li>⏰ <strong>Horario:</strong> 09:00 a 17:00 hrs (Incluye Comida-Cena)</li>
              <li>📍 <strong>Sede:</strong> Instalaciones de Zoeller México (Zapopan, Jal.)</li>
            </ul>

            <p class="card-description">
              Inmersión técnica en la tecnología trituradora bidireccional Zoeller, dimensionamiento preciso de cárcamos presurizados y aplicaciones de drenaje en proyectos complejos.
            </p>
          </div>

          <div class="card-footer">
            <a href="/eventos/zoeller" class="btn-card btn-zoeller">
              VER AGENDA Y SOLICITAR REGISTRO >
            </a>
          </div>
        </article>

        <!-- TARJETA 2: EVENTO GRUNDFOS -->
        <article class="event-card border-grundfos">
          <div class="card-header">
            <span class="badge-tech badge-grundfos">SISTEMAS HVAC / EFICIENCIA</span>
            <span class="event-status">CUPO LIMITADO</span>
          </div>

          <div class="card-body">
            <h3>Curso Técnico Grundfos: Ahorro Energético HVAC & Bombeo Distribuido</h3>
            
            <ul class="event-meta-list">
              <li>📅 <strong>Fecha:</strong> 27 de Agosto, 2026</li>
              <li>⏰ <strong>Horario:</strong> 11:00 a 14:00 hrs (Incluye Coffee Break & Snacks)</li>
              <li>📍 <strong>Sede:</strong> Cámara de Comercio de Tlaquepaque (Tlaquepaque, Jal.)</li>
            </ul>

            <p class="card-description">
              Optimización de Delta T en chiller plantas, eliminación del balanceo pasivo con Equipos Delta y estrategias de bombeo distribuido para reducción drástica de kWh.
            </p>
          </div>

          <div class="card-footer">
            <a href="/eventos/grundfos" class="btn-card btn-grundfos">
              VER AGENDA Y SOLICITAR REGISTRO >
            </a>
          </div>
        </article>

        <!-- TARJETA 3: CAPTURA PARA FUTUROS EVENTOS -->
        <article class="event-card border-future">
          <div class="card-header">
            <span class="badge-tech badge-future">PRÓXIMAS FECHAS / NOTIFICACIONES</span>
          </div>

          <div class="card-body">
            <h3>¿No puedes asistir en agosto? Recibe convocatorias exclusivas</h3>
            
            <p class="card-description">
              Déjanos tus datos para recibir la agenda de seminarios del segundo semestre de 2026 antes de la publicación abierta.
            </p>

            <form id="future-events-form" class="future-form">
              <div class="form-group-sub">
                <input type="text" name="nombre" required placeholder="Nombre Completo" />
              </div>
              <div class="form-group-sub">
                <input type="email" name="correo" required placeholder="Correo Corporativo" />
              </div>
              <div class="form-group-sub">
                <input type="tel" name="whatsapp" required placeholder="WhatsApp de Contacto" />
              </div>

              <button type="submit" id="sub-btn" class="btn-card btn-future">
                RECIBIR PRÓXIMAS FECHAS >
              </button>
            </form>

            <div id="sub-success-message" class="sub-success-box" style="display: none;">
              ✅ <strong>¡Gracias por suscribirte!</strong> Te notificaremos en cuanto abramos nuevas fechas.
            </div>
          </div>
        </article>

      </div>
    </div>
  </main>

  <!-- Footer Del Hub -->
  <footer class="footer-hub">
    <div class="section-container">
      <p>Organizado por SIBI en alianza con Zoeller México y Grundfos para impulsar la ingeniería de alto rendimiento.</p>
      <p class="footer-copyright">© 2026 Current Command. Todos los derechos reservados.</p>
    </div>
  </footer>

  <!-- Lógica de Registro para la Suscripción de Futuros Eventos -->
  <script is:inline>
    const subForm = document.getElementById('future-events-form');
    const subSuccessMessage = document.getElementById('sub-success-message');
    const subBtn = document.getElementById('sub-btn');

    // Mismo Apps Script o uno nuevo para guardar interesados en próximas fechas
    const GOOGLE_SCRIPT_URL = 'https://script.google.com/macros/s/AKfycbwnVxvsaLaprumpCk14-UeEtJRrBDHXx0NhWBNE6DAr29EwQYcDmqPMGOzhB9wPVwewYA/exec';

    subForm.addEventListener('submit', async (e) => {
      e.preventDefault();
      
      subBtn.disabled = true;
      subBtn.innerText = 'GUARDANDO...';

      const formData = new FormData(subForm);
      const data = {
        fecha_registro: new Date().toLocaleString('es-MX', { timeZone: 'America/Mexico_City' }),
        nombre: formData.get('nombre'),
        empresa: 'Interesado en Futuros Eventos',
        correo: formData.get('correo'),
        whatsapp: formData.get('whatsapp'),
        interes: 'Notificaciones Futuras Capacitaciones'
      };

      try {
        await fetch(GOOGLE_SCRIPT_URL, {
          method: 'POST',
          mode: 'no-cors',
          headers: { 'Content-Type': 'text/plain' },
          body: JSON.stringify(data)
        });

        subForm.style.display = 'none';
        subSuccessMessage.style.display = 'block';

      } catch (error) {
        console.error('Error:', error);
        alert('Ocurrió un error al guardar la suscripción. Por favor intente de nuevo.');
        subBtn.disabled = false;
        subBtn.innerText = 'RECIBIR PRÓXIMAS FECHAS >';
      }
    });
  </script>
</Layout>

<!-- Estilos Avanzados Encapsulados del Hub -->
<style>
  :root {
    --zoeller-green: #006b30;
    --zoeller-light: #008542;
    --grundfos-blue: #00519e;
    --grundfos-dark: #002b49;
    --dark-charcoal: #111827;
    --slate-gray: #4b5563;
    --bg-premium: #f9fafb;
    --border-color: #e5e7eb;
  }

  .section-container {
    max-width: 1100px;
    margin: 0 auto;
    padding: 0 24px;
  }

  /* NAVBAR HUB */
  .navbar-hub {
    position: sticky;
    top: 0;
    z-index: 100;
    background: #ffffff;
    border-bottom: 1px solid var(--border-color);
    padding: 16px 0;
  }
  .nav-container-hub {
    display: flex;
    justify-content: space-between;
    align-items: center;
    max-width: 1100px;
    margin: 0 auto;
    padding: 0 24px;
  }
  .brand-logos-hub {
    display: flex;
    align-items: center;
    gap: 10px;
    font-weight: 900;
    font-size: 20px;
  }
  .logo-sibi { color: var(--dark-charcoal); }
  .logo-divider { color: var(--border-color); font-weight: 300; }
  .logo-sub { color: var(--slate-gray); font-size: 14px; font-weight: 800; letter-spacing: 0.5px; }
  
  .badge-year {
    background-color: var(--dark-charcoal);
    color: #ffffff;
    font-size: 11px;
    font-weight: 800;
    padding: 6px 12px;
    border-radius: 4px;
    letter-spacing: 0.5px;
  }

  /* HERO HUB */
  .hero-hub {
    padding: 60px 0 40px 0;
    background: linear-gradient(180deg, #ffffff 0%, var(--bg-premium) 100%);
    border-bottom: 1px solid var(--border-color);
  }
  .hero-container-hub {
    max-width: 1100px;
    margin: 0 auto;
    padding: 0 24px;
  }
  .hero-kicker {
    font-size: 12px;
    font-weight: 800;
    color: var(--slate-gray);
    letter-spacing: 1px;
    margin-bottom: 10px;
  }
  .hero-hub h1 {
    font-size: 38px;
    font-weight: 900;
    line-height: 1.15;
    color: var(--dark-charcoal);
    margin: 0 0 20px 0;
    max-width: 900px;
  }
  .hero-lead {
    font-size: 17px;
    line-height: 1.6;
    color: var(--slate-gray);
    max-width: 850px;
    margin: 0;
  }

  /* MAIN CONTENT & GRID */
  .main-hub-content {
    padding: 60px 0 80px 0;
  }
  .events-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(320px, 1fr));
    gap: 30px;
  }

  .event-card {
    background: #ffffff;
    border: 1px solid var(--border-color);
    border-radius: 6px;
    padding: 30px;
    display: flex;
    flex-direction: column;
    justify-content: space-between;
    transition: transform 0.2s, box-shadow 0.2s;
  }
  .event-card:hover {
    transform: translateY(-3px);
    box-shadow: 0 10px 20px rgba(0,0,0,0.05);
  }

  .border-zoeller { border-top: 5px solid var(--zoeller-green); }
  .border-grundfos { border-top: 5px solid var(--grundfos-blue); }
  .border-future { border-top: 5px solid var(--dark-charcoal); background-color: var(--bg-premium); }

  .card-header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-bottom: 20px;
  }

  .badge-tech {
    font-size: 10px;
    font-weight: 900;
    padding: 5px 10px;
    border-radius: 4px;
    letter-spacing: 0.5px;
  }
  .badge-zoeller { background-color: #e6f4ea; color: var(--zoeller-green); }
  .badge-grundfos { background-color: #e6f0fa; color: var(--grundfos-blue); }
  .badge-future { background-color: #e5e7eb; color: var(--dark-charcoal); }

  .event-status {
    font-size: 10px;
    font-weight: 800;
    color: #b91c1c;
    background-color: #fef2f2;
    padding: 4px 8px;
    border-radius: 4px;
  }

  .card-body h3 {
    font-size: 20px;
    font-weight: 900;
    color: var(--dark-charcoal);
    margin: 0 0 15px 0;
    line-height: 1.3;
  }

  .event-meta-list {
    list-style: none;
    padding: 0;
    margin: 0 0 15px 0;
    font-size: 13px;
    line-height: 1.6;
    color: var(--dark-charcoal);
  }

  .card-description {
    font-size: 14px;
    color: var(--slate-gray);
    line-height: 1.5;
    margin-bottom: 25px;
  }

  .btn-card {
    display: block;
    width: 100%;
    text-align: center;
    padding: 14px 0;
    font-size: 12px;
    font-weight: 800;
    border-radius: 4px;
    text-decoration: none;
    letter-spacing: 0.5px;
    box-sizing: border-box;
    transition: background 0.2s;
  }

  .btn-zoeller { background-color: var(--zoeller-green); color: #ffffff; }
  .btn-zoeller:hover { background-color: var(--zoeller-light); }

  .btn-grundfos { background-color: var(--grundfos-blue); color: #ffffff; }
  .btn-grundfos:hover { background-color: var(--grundfos-dark); }

  .btn-future { background-color: var(--dark-charcoal); color: #ffffff; border: none; cursor: pointer; }
  .btn-future:hover { background-color: #374151; }

  /* FORMULARIO SUSCRIPCIÓN */
  .future-form {
    display: flex;
    flex-direction: column;
    gap: 12px;
  }
  .form-group-sub input {
    width: 100%;
    padding: 10px 12px;
    border: 1px solid #d1d5db;
    border-radius: 4px;
    font-size: 13px;
    box-sizing: border-box;
  }
  .sub-success-box {
    margin-top: 15px;
    padding: 12px;
    background-color: #d1e7dd;
    color: #0f5132;
    border-radius: 4px;
    font-size: 12px;
    text-align: center;
  }

  /* FOOTER HUB */
  .footer-hub {
    background-color: var(--bg-premium);
    border-top: 1px solid var(--border-color);
    padding: 40px 0;
    text-align: center;
    font-size: 13px;
    color: var(--slate-gray);
  }
  .footer-copyright { font-size: 11px; color: #9ca3af; margin-top: 10px; }

  @media (max-width: 768px) {
    .hero-hub h1 { font-size: 28px; }
    .events-grid { grid-template-columns: 1fr; }
  }
</style>