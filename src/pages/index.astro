---
// src/pages/index.astro
import Layout from '../layouts/Layout.astro';
import { Image } from 'astro:assets';

// Importación de la imagen para procesamiento automático (WebP/AVIF + Resizing)
import hydroMpcImage from '../assets/Hydro_MPC_Grundfos.webp';

// Iconos: Para mantener 0 JS, usamos componentes de Lucide pero como SVGs estáticos
import { CheckCircle, Activity, Ruler, ShieldCheck } from 'lucide-react';

// Título dinámico para SEO
const title = "Inicio | CURRENT COMMAND - Ingeniería de Bombeo";
---

<Layout title={title}>
  <div class="flex flex-col min-h-screen">
    
    {/* Hero Section - Optimizado para LCP */}
    <section class="relative bg-slate-900 py-24 md:py-32 overflow-hidden">
      <div class="absolute inset-0 bg-slate-900 opacity-20 mix-blend-overlay"></div>
      
      <div class="container mx-auto px-4 relative z-10">
        <div class="flex flex-col md:flex-row items-center gap-12">
          
          {/* Texto Principal */}
          <div class="w-full md:w-1/2">
            <h1 class="text-4xl md:text-6xl font-bold text-white font-mono tracking-tighter mb-6">
              INGENIERÍA DE BOMBEO <br class="hidden md:block" />
              PARA EL MUNDO REAL
            </h1>
            <p class="text-lg md:text-xl text-gray-300 mb-8 leading-relaxed max-w-2xl">
              18 años de experiencia en campo resolviendo desafíos hidráulicos.
              Distribuidores autorizados Grundfos, Wolf y Zoeller. Respaldo SIBI.
            </p>
            <div class="flex flex-col sm:flex-row gap-4">
              <a href="/productos" class="inline-flex items-center justify-center px-8 py-3 text-base font-bold text-white bg-blue-700 hover:bg-blue-800 transition-colors rounded-none shadow-lg">
                VER EQUIPOS
              </a>
              <a href="/contacto" class="inline-flex items-center justify-center px-8 py-3 text-base font-bold text-white border-2 border-white hover:bg-white hover:text-slate-900 transition-colors rounded-none">
                CONSULTAR A UN INGENIERO
              </a>
            </div>
          </div>

          {/* Imagen del Hydro MPC - Solución CLS y LCP */}
          <div class="w-full md:w-1/2">
            <Image 
              src={hydroMpcImage} 
              alt="Sistema de presión constante Hydro MPC de Grundfos" 
              width={800} 
              height={600}
              loading="eager" 
              fetchpriority="high"
              class="w-full h-auto shadow-2xl grayscale hover:grayscale-0 transition-all duration-500 rounded-sm border border-slate-700"
            />
          </div>
        </div>
      </div>
    </section>

    {/* Authority Section */}
    <section class="py-20 bg-white">
      <div class="container mx-auto px-4">
        <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
          
          <div class="p-8 border border-gray-200 hover:border-blue-700 transition-colors group">
            <div class="w-12 h-12 bg-slate-100 flex items-center justify-center mb-6 group-hover:bg-blue-700 group-hover:text-white transition-colors">
              <Activity size={24} />
            </div>
            <h3 class="text-xl font-bold text-slate-800 mb-3 font-mono">Diagnóstico de Fallas</h3>
            <p class="text-slate-600 text-sm leading-relaxed">
              Analizamos por qué falló su equipo anterior y proponemos soluciones que atacan la raíz del problema.
            </p>
          </div>

          <div class="p-8 border border-gray-200 hover:border-blue-700 transition-colors group">
            <div class="w-12 h-12 bg-slate-100 flex items-center justify-center mb-6 group-hover:bg-blue-700 group-hover:text-white transition-colors">
              <Ruler size={24} />
            </div>
            <h3 class="text-xl font-bold text-slate-800 mb-3 font-mono">Cálculo Hidráulico Real</h3>
            <p class="text-slate-600 text-sm leading-relaxed">
              Evite el sobredimensionamiento. Cálculos precisos basados en su curva de operación.
            </p>
          </div>

          <div class="p-8 border border-gray-200 hover:border-blue-700 transition-colors group">
            <div class="w-12 h-12 bg-slate-100 flex items-center justify-center mb-6 group-hover:bg-blue-700 group-hover:text-white transition-colors">
              <ShieldCheck size={24} />
            </div>
            <h3 class="text-xl font-bold text-slate-800 mb-3 font-mono">Equipos Certificados</h3>
            <p class="text-slate-600 text-sm leading-relaxed">
              Suministro con certificaciones internacionales UL/FM y normativas sanitarias vigentes.
            </p>
          </div>
        </div>
      </div>
    </section>

    {/* Respaldo Técnico Section */}
    <section class="py-20 bg-slate-50 border-t border-gray-200">
      <div class="container mx-auto px-4 flex flex-col md:flex-row items-center gap-12">
        <div class="w-full md:w-1/2">
          <h2 class="text-3xl font-bold text-slate-800 mb-6 font-mono">RESPALDO TÉCNICO TOTAL</h2>
          <p class="text-slate-600 mb-6">
            Detrás de CURRENT COMMAND está la infraestructura de <strong>SIBI SA DE CV</strong>.
            Con base en Tlaquepaque, Jalisco, atendemos a la industria en todo el occidente del país.
          </p>
          <ul class="space-y-3 mb-8">
            <li class="flex items-center text-sm text-slate-700">
              <CheckCircle size={18} class="text-blue-700 mr-3" />
              Taller de servicio autorizado
            </li>
            <li class="flex items-center text-sm text-slate-700">
              <CheckCircle size={18} class="text-blue-700 mr-3" />
              Stock de refacciones críticas
            </li>
            <li class="flex items-center text-sm text-slate-700">
              <CheckCircle size={18} class="text-blue-700 mr-3" />
              Puesta en marcha y alineación láser
            </li>
          </ul>
        </div>
      </div>
    </section>
  </div>
</Layout>