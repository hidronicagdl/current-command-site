              <td class="p-4 bg-industrial-blue/5 text-emerald-600 font-medium">Sí (Acción por cizallamiento plano)</td>
              <td class="p-4 font-medium text-amber-600">No (Ajuste mecánico por desgaste)</td>
              <td class="p-4">Sí (Anillo adaptativo)</td>
              <td class="p-4 text-amber-600">No (Requiere mantenimiento)</td>
              <td class="p-4 text-amber-600">No (Desgaste rápido con sólidos)</td>
              <td class="p-4">Sí (Mecanismo de cizalla axial)</td>
            </tr>
            <tr class="hover:bg-steel-light/30 transition-all">
              <td class="p-4 font-semibold text-slate-900">Sensores Integrados de Fábrica</td>
              <td class="p-4 bg-industrial-blue/5">Protección térmica devanado</td>
              <td class="p-4 bg-industrial-blue/5 font-bold text-industrial-blue">Sí (Sensor de humedad/sello y térmico estándar)</td>
              <td class="p-4">Térmico estándar (Humedad opcional)</td>
              <td class="p-4">Sí (Sensor de fuga y térmico)</td>
