              <td class="p-4 bg-industrial-blue/5">Sí (Aceite Dieléctrico de Enfriamiento)</td>
              <td class="p-4">Sí (Aceite Dieléctrico)</td>
              <td class="p-4 font-medium text-amber-600">No (Motor Seco, cámara aislada)</td>
              <td class="p-4">Sí (Aceite Dieléctrico)</td>
              <td class="p-4">Sí (Aceite Dieléctrico)</td>
              <td class="p-4">Sí (Aceite Dieléctrico)</td>
            </tr>
            <tr class="hover:bg-steel-light/30 transition-all">
              <td class="p-4 font-semibold text-slate-900">Camisa de Enfriamiento</td>
              <td class="p-4 bg-industrial-blue/5 text-slate-400">No requiere (Diseño sumergible)</td>
              <td class="p-4 bg-industrial-blue/5 text-slate-400">No requiere (Diseño sumergible)</td>
              <td class="p-4 text-slate-400">No</td>
              <td class="p-4 text-emerald-600 font-medium">Sí (Opcional según modelo)</td>
              <td class="p-4 text-slate-400">No</td>
              <td class="p-4 text-slate-400">No</td>
              <td class="p-4 text-slate-400">No</td>
            </tr>
            <tr class="hover:bg-steel-light/30 transition-all">
              <td class="p-4 font-semibold text-slate-900">Aletas de Enfriamiento</td>
